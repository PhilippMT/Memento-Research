# OpenRouter API (used as OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default model (used if not overridden per-agent in founding_employees.yaml)
DEFAULT_LLM_MODEL=openai/gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
HOT_RELOAD=true

# OpenSandbox
SANDBOX_ENABLED=false
SANDBOX_SERVER_URL=http://localhost:8080
SANDBOX_DEFAULT_IMAGE=opensandbox/code-interpreter:v1.0.1
SANDBOX_TIMEOUT_SECONDS=120

# Talent Market
TALENT_MARKET_URL=https://api.one-man-company.com/mcp/sse
TALENT_MARKET_API_KEY=
TALENT_MARKET_USE_AI_SEARCH=false
TALENT_MARKET_MODE=local
