{
  "id": "experiment-runner",
  "name": "Experiment Runner",
  "version": "1.0.0",
  "role": "Engineer",
  "hosting": "company",
  "settings": {
    "sections": [
      {
        "id": "infra_api",
        "title": "Remote Experiment API",
        "fields": [
          {
            "key": "infra_server_url",
            "type": "text",
            "label": "INFRA_SERVER_URL",
            "default": "",
            "placeholder": "http://your-infra-host:port"
          },
          {
            "key": "infra_session_key",
            "type": "secret",
            "label": "INFRA_SESSION_KEY",
            "placeholder": "vk_..."
          }
        ]
      },
      {
        "id": "polling",
        "title": "Polling Behavior",
        "fields": [
          {
            "key": "poll_interval_minutes",
            "type": "number",
            "label": "Status poll interval (minutes)",
            "default": 2,
            "min": 1,
            "max": 30,
            "step": 1
          },
          {
            "key": "default_summary_only",
            "type": "boolean",
            "label": "Pull log_tail only on terminal status",
            "default": true
          }
        ]
      }
    ]
  },
  "prompts": {
    "skills": ["skills/*/SKILL.md"]
  },
  "tools": {
    "builtin": [],
    "custom": []
  },
  "platform_capabilities": []
}
